NODE_ENV=production
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=https://oryxcontrol.com,https://www.oryxcontrol.com
SWAGGER_ENABLED=true

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/oryx?schema=public
REDIS_URL=rediss://:PASSWORD@HOST:6379

JWT_ACCESS_SECRET=replace-with-48-byte-random-base64url
JWT_REFRESH_SECRET=replace-with-different-48-byte-random-base64url
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PASSWORD_RESET_TTL_SECONDS=3600
EMAIL_VERIFICATION_TTL_SECONDS=86400

MQTT_MODE=stub
MQTT_CREDENTIAL_TTL_SECONDS=3600
AWS_REGION=sa-east-1
# AWS_IOT_ENDPOINT=
# AWS_IOT_ROLE_ARN=

NOTIFICATIONS_MODE=stub
# FCM_PROJECT_ID=
# FCM_CREDENTIALS_JSON=

VOICE_MODE=stub
VOICE_TOKEN_TTL_SECONDS=3600
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
