NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Sentry crash reporting (optional). Leave empty to skip init.
# SENTRY_DSN=https://210abead0906ee2478e69c85dbf5154a@o4511267865231360.ingest.us.sentry.io/4511269849464832
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# PostgreSQL connection (matches docker-compose.yml defaults for local dev)
DATABASE_URL=postgresql://oryx:oryx@localhost:55432/oryx?schema=public

# Redis connection (matches docker-compose.yml defaults for local dev)
REDIS_URL=redis://localhost:16379

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Each must be at least 32 chars. Use DIFFERENT values for access and refresh.
JWT_ACCESS_SECRET=replace-me-with-32-or-more-random-chars-aaaa
JWT_REFRESH_SECRET=replace-me-with-32-or-more-random-chars-bbbb
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# MQTT / AWS IoT Core (sessão 1.8)
# `stub` returns a fake but well-formed WSS URL — dev mobile can integrate
# without an AWS account. `aws` will plug STS:AssumeRole + SigV4 in the
# deploy session; until then it returns 501.
MQTT_MODE=stub
MQTT_CREDENTIAL_TTL_SECONDS=3600
AWS_REGION=sa-east-1
# AWS_IOT_ENDPOINT=a1b2c3d4-ats.iot.sa-east-1.amazonaws.com  # only when MQTT_MODE=aws
# AWS_IOT_ROLE_ARN=arn:aws:iam::ACCOUNT:role/oryx-iot-credentials

# Notifications / FCM (sessão 1.14)
# `stub` flips notifications to SENT without contacting Firebase — useful for
# dev. `fcm` will plug firebase-admin in the deploy session; until then it 501s.
NOTIFICATIONS_MODE=stub
# FCM_PROJECT_ID=oryx-control                    # only when NOTIFICATIONS_MODE=fcm
# FCM_CREDENTIALS_JSON=/run/secrets/fcm-sa.json  # path to service account JSON

# Voice / LiveKit (sessão 1.18)
# `stub` mints a structurally-valid opaque token without contacting LiveKit —
# useful for dev. `livekit` will sign HS256 tokens via livekit-server-sdk in
# the deploy session; until then it 501s.
VOICE_MODE=stub
VOICE_TOKEN_TTL_SECONDS=3600
# When VOICE_MODE=livekit, set the three below (LiveKit Cloud project ORYX):
# LIVEKIT_URL=wss://oryx-vrw0ssg8.livekit.cloud
# LIVEKIT_API_KEY=APIQPQKPtjqpWQP
# LIVEKIT_API_SECRET=replace-from-livekit-console      # NEVER commit the real value
