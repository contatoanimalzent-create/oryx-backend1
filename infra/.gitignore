# Local .terraform directories (modules, providers, plugins)
**/.terraform/*

# .tfstate files (NEVER commit — may contain secrets)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json
!example.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration / plan artifacts
.terraformrc
terraform.rc
*.tfplan
